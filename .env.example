# ============================================================
# Opsicos - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults.
# ============================================================

# ─── Discord OAuth2 [REQUIRED] ──────────────────────────────
# Create an application at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# ─── Discord Official Bot [OPTIONAL] ────────────────────────
# Token for the official Opsicos platform bot (slash commands, tickets)
# If not set, the official bot features will be disabled.
OFFICIAL_BOT_TOKEN=your_official_bot_token

# Discord server ID for auto-joining users on login
DISCORD_GUILD_ID=your_discord_server_id

# Channel ID for posting changelog updates
CHANGELOG_CHANNEL_ID=your_changelog_channel_id

# ─── MongoDB [REQUIRED] ─────────────────────────────────────
# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/opsicos

# ─── Session & Security [REQUIRED] ──────────────────────────
# A strong random string used to sign session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# ─── Admin Panel [REQUIRED] ─────────────────────────────────
# Password for the /admin panel
ADMIN_PASSWORD=your_admin_password

# ─── AI Model Providers [REQUIRED for bot AI] ───────────────
# A4F API (primary multi-model aggregator) — https://a4f.co
A4F_PRIMARY_API_KEY=your_a4f_primary_api_key
A4F_BACKUP_API_KEY=your_a4f_backup_api_key
A4F_BASE_URL=https://api.a4f.co/v1

# ─── Custom AI Providers [OPTIONAL] ─────────────────────────
# Zhipu AI (GLM models)
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_API_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Anthropic-compatible router (Claude models)
ANTHROPIC_ROUTER_API_KEY=your_anthropic_router_api_key
ANTHROPIC_ROUTER_BASE_URL=https://your-anthropic-router.example.com

# ─── Application [OPTIONAL] ─────────────────────────────────
# Public URL of your deployment (used in Discord embeds and branding)
APP_URL=http://localhost:3000

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# ─── Email (Contact Form) [OPTIONAL] ────────────────────────
# For Gmail: Use an App Password, not your regular password
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Send confirmation emails to users who submit the contact form
SEND_CONFIRMATION=false

# ─── Rate Limiting (Advanced) [OPTIONAL] ────────────────────
# Time in ms between bot starts (default: 15000)
BOT_START_INTERVAL=15000

# Maximum concurrent bot starts (default: 2)
MAX_CONCURRENT_STARTS=2

# Health check interval in ms (default: 300000 = 5 minutes)
HEALTH_CHECK_INTERVAL=300000
