# Android App Environment Variables Example

# Mobile API Key - Generate a secure key for mobile app authentication
MOBILE_API_KEY=osk_personal_your_secure_api_key_here

# Admin Password - Used for accessing the Android app admin panel
ANDROID_ADMIN_PASSWORD=your_secure_admin_password

# API Base URL - Your backend server URL
API_BASE_URL=https://opsicos.onrender.com

# App Version Info
APP_VERSION=1.0.0
APP_VERSION_CODE=1
